{"nl": "Natural language: find repeated error messages", "query": "level=error | stats count as occurrences by message | where occurrences > 1 | sort -occurrences", "category": "nl_example"}
{"nl": "Natural language: most common status codes", "query": "| stats count by status | sort -count | head 10", "category": "nl_example"}
{"nl": "Natural language: track a specific user's activity", "query": "user_id=42 | sort _time | table _time, action, endpoint, status", "category": "nl_example"}
{"nl": "Natural language: hour-over-hour comparison", "query": "| bin _time span=1h | stats count by _time | streamstats avg(count) as hourly_avg", "category": "nl_example"}
{"nl": "Where with complex boolean", "query": "| where (status >= 500 AND source == \"nginx\") OR (level == \"error\" AND duration_ms > 5000)", "category": "filter"}
{"nl": "Stats with percentile alias", "query": "| stats perc95(duration_ms) as p95_latency by endpoint", "category": "aggregate"}
{"nl": "Eval with nested if", "query": "| eval bucket=if(duration_ms<100, \"fast\", if(duration_ms<1000, \"medium\", if(duration_ms<5000, \"slow\", \"very_slow\")))", "category": "transform"}
{"nl": "Multiple eval assignments", "query": "| eval is_error=if(status>=500, 1, 0), is_warn=if(status>=400 AND status<500, 1, 0)", "category": "transform"}
{"nl": "Stats and sort pipeline", "query": "| stats count, avg(duration_ms) as avg_dur by endpoint | sort -avg_dur | head 5", "category": "pipeline"}
{"nl": "Extract JSON and aggregate", "query": "| unpack_json | stats count by level, service", "category": "pipeline"}
{"nl": "Logfmt parsing and filtering", "query": "| unpack_logfmt | where level=error | stats count by component", "category": "pipeline"}
{"nl": "Full pipeline: filter, eval, aggregate, sort", "query": "source=nginx | eval is_error=if(status>=500, true, false) | stats count by is_error | sort -count", "category": "pipeline"}
{"nl": "Cross-source correlation", "query": "search \"timeout\" | stats count by source, host | where count > 10 | sort -count", "category": "pipeline"}
{"nl": "Trend detection", "query": "level=error | timechart count span=5m | streamstats window=12 avg(count) as trend | where count > trend * 2", "category": "pipeline"}
{"nl": "Anomaly detection with streamstats", "query": "| timechart count span=1m | streamstats window=60 avg(count) as avg, stdev(count) as std | where count > avg + 3*std", "category": "pipeline"}
{"nl": "Bucket and top", "query": "| bucket duration_ms span=100 | top 5 duration_ms", "category": "pipeline"}
{"nl": "Multi-source error dashboard query", "query": "level=error | stats count by source | sort -count", "category": "pipeline"}
{"nl": "Service health summary", "query": "| stats count, perc95(duration_ms) as p95, avg(duration_ms) as avg by source | eval healthy=if(p95 < 1000, \"yes\", \"no\")", "category": "pipeline"}
{"nl": "Latency histogram", "query": "| bucket duration_ms span=50 | stats count by duration_ms | sort +duration_ms", "category": "pipeline"}
